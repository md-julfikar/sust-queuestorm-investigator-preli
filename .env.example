# =====================================================================
# QueueStorm Investigator Configuration Example
# Copy this file to '.env' and fill in your actual Gemini API Key.
# =====================================================================

# Server Binding Config
HOST=0.0.0.0
PORT=8000
DEBUG=False

# LLM Configuration
# Retrieve your key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Model identifier (gemini-2.5-flash is default and recommended)
GEMINI_MODEL=gemini-2.5-flash

# Timeout for external API requests in seconds
REQUEST_TIMEOUT_SEC=15.0
